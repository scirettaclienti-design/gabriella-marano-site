---
interface Props {
  heading: string;
  lead?: string;
}

const { heading, lead } = Astro.props;
---

<section class="relative px-6 py-32 md:py-48">
  <div class="mx-auto max-w-3xl">
    <p class="eyebrow mb-6 text-bone-faint">Gabriella Marano</p>
    <h1 class="font-display text-5xl leading-tight md:text-7xl">{heading}</h1>
    {lead && <p class="mt-8 max-w-xl text-lg text-bone-dim md:text-xl">{lead}</p>}
  </div>
</section>
