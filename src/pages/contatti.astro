---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contatti"
  description="Stampa, perizie, formazione: tre canali distinti."
>
  <section class="mx-auto max-w-3xl px-6 py-24">
    <p class="eyebrow mb-6 text-bone-faint">Contatti</p>
    <h2 class="font-display text-4xl md:text-6xl">Tre canali, tre risposte.</h2>
    <p class="mt-8 text-lg text-bone-dim">
      Pagina in costruzione — stampa, perizie, formazione.
    </p>
  </section>
</Base>
