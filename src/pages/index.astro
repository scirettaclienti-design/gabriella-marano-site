---
import { Picture } from 'astro:assets';
import Base from '../layouts/Base.astro';
import heroMarble from '../assets/images/hero-marble.jpg';
import lavoroPaper from '../assets/images/lavoro-paper.jpg';
import archeTheatre from '../assets/images/arche-theatre.jpg';
import gmPortrait from '../assets/images/gm/gm-portrait-1.jpg';
---

<Base
  title="Home"
  description="Gabriella Marano: psicologa clinica e forense, criminologa. Nei tribunali, nei media, nelle aule — ascoltare, ricostruire, restituire."
>
  <main>

  {/* HERO — full-bleed background image (treated), monumental h1, framed portrait slot. */}
  <section
    id="hero"
    class="relative min-h-screen overflow-hidden"
  >
    {/* Background image layer — heavily treated, eager-loaded for LCP.
        TODO replace with the real editorial portrait of Gabriella as full-bleed,
        or composite hers behind the title. */}
    <div class="absolute inset-0 z-0">
      <Picture
        src={heroMarble}
        alt=""
        formats={['avif', 'webp']}
        widths={[420, 768, 1280, 1920, 2560]}
        sizes="100vw"
        quality={72}
        loading="eager"
        fetchpriority="high"
        data-unearth-bg
        class="hero-bg-image h-full w-full object-cover"
      />
      {/* Strong dark overlay so text stays the protagonist */}
      <div
        class="absolute inset-0"
        style="background: linear-gradient(rgba(20,17,12,0.92), rgba(20,17,12,0.62));"
      ></div>
      {/* Gold ambient corner */}
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 65vw 55vh at 100% -5%, rgba(200,162,78,0.10), transparent 62%);"
      ></div>
    </div>

    {/* Content layer */}
    <div class="relative z-10 flex min-h-screen flex-col justify-center px-6 pb-24 pt-32 md:pt-40">
      <div class="mx-auto grid w-full max-w-wide grid-cols-1 items-center gap-14 md:grid-cols-[1.27fr_1fr] md:gap-16">

        <div>
          <p id="hero-eyebrow" class="eyebrow mb-8">
            Psicologa clinica e forense · Criminologa
          </p>
          <h1
            id="hero-h1"
            data-unearth-hero
            class="font-display tracking-tight text-bone"
            style="font-size: clamp(2.75rem, 9vw, 8rem); line-height: 0.92; letter-spacing: -0.015em;"
          >
            <span class="word">La</span>
            <span class="word">verità,</span><br />
            <span class="word">in</span>
            <span class="word">ogni</span>
            <span class="word">dettaglio.</span>
          </h1>
          <div data-ground-line aria-hidden="true" class="ground-line"></div>
          <p id="hero-lead" class="mt-10 max-w-md font-serif text-lg leading-relaxed text-bone-dim md:text-xl">
            Nei tribunali, nei media, nelle aule. Ascolto, ricostruisco,
            restituisco. Con gli altri, per gli altri.
          </p>
        </div>

        {/* Portrait — real editorial portrait of Gabriella, framed by a gold hairline */}
        <div
          id="hero-portrait"
          class="portrait-frame relative aspect-[4/5] w-full overflow-hidden"
        >
          <Picture
            src={gmPortrait}
            alt="Ritratto di Gabriella Marano"
            formats={['avif', 'webp']}
            widths={[420, 600, 900, 1050]}
            sizes="(min-width: 768px) 44vw, 100vw"
            quality={80}
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>

      </div>

      <a
        id="hero-scroll-hint"
        href="#storia-anticipo"
        class="absolute bottom-8 left-6 font-sans text-xs uppercase tracking-eyebrow text-bone-dim transition hover:text-gold"
      >
        ↓ La mia storia
      </a>
    </div>
  </section>


  {/* LA MIA STORIA — anticipo. Giant faded "ORIGINE" bleeds right. */}
  <section
    id="storia-anticipo"
    class="relative overflow-hidden px-6"
    style="padding-block: var(--space-band)"
  >
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -right-6 -top-2 select-none font-secret italic leading-none md:-right-20 md:top-12"
      style="font-size: clamp(3.5rem, 14vw, 14rem); color: rgba(200, 162, 78, 0.06);"
    >ORIGINE</span>

    <div class="relative mx-auto max-w-text">
      <p data-reveal class="eyebrow mb-8">La mia storia</p>
      <h2 data-reveal class="vt-storia-heading font-display text-3xl leading-tight tracking-tight text-bone md:text-4xl">
        {"Una storia, molte storie.".split(' ').map((w, i, arr) => (
          <Fragment>
            <span class="word">{w}</span>{i < arr.length - 1 ? ' ' : ''}
          </Fragment>
        ))}
      </h2>
      <p data-reveal class="home-storia-lead mt-10 font-serif leading-loose text-bone">
        Prima di occuparmi di crimini, mi sono occupata di rovine. Una laurea
        in Beni Archeologici, poi Psicologia Clinica e Scienze Forensi. Non
        un cambio di rotta: lo stesso gesto, su una materia diversa. Partire
        dai frammenti e lasciare che la forma emerga.
      </p>
      <a data-reveal href="/storia" class="cta-link mt-10">La mia storia →</a>
    </div>
  </section>


  {/* IL MIO LAVORO — bg paper texture (very dark), 3 doors */}
  <section
    id="lavoro"
    class="relative overflow-hidden px-6"
    style="padding-block: var(--space-band)"
  >
    <div class="absolute inset-0 z-0">
      <Picture
        src={lavoroPaper}
        alt=""
        formats={['avif', 'webp']}
        widths={[420, 768, 1280, 1920]}
        sizes="100vw"
        quality={65}
        loading="lazy"
        class="lavoro-bg-image h-full w-full object-cover"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(rgba(20,17,12,0.94), rgba(20,17,12,0.82));"
      ></div>
      <div data-curtain-veil aria-hidden="true" class="absolute inset-0 bg-ink"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-wide">
      <p data-reveal class="eyebrow mb-12">Il mio lavoro</p>

      <div class="lavoro-doors grid grid-cols-1 md:grid-cols-3">

        <article data-reveal tabindex="0" class="door px-2 py-12 md:px-10 md:py-4">
          <span
            data-numeral
            aria-hidden="true"
            class="mb-8 block font-secret leading-none"
            style="font-size: clamp(4.5rem, 8vw, 6.5rem); color: rgba(200, 162, 78, 0.5);"
          >I</span>
          <h3 class="font-display text-2xl tracking-tight text-bone md:text-3xl">Civile</h3>
          <p class="mt-5 font-serif leading-loose text-bone-dim">
            Danno psichico, capacità genitoriali, consulenze tecniche.
          </p>
        </article>

        <article
          data-reveal
          tabindex="0"
          class="door border-t px-2 py-12 md:border-l md:border-t-0 md:px-10 md:py-4"
          style="border-color: var(--line)"
        >
          <span
            data-numeral
            aria-hidden="true"
            class="mb-8 block font-secret leading-none"
            style="font-size: clamp(4.5rem, 8vw, 6.5rem); color: rgba(200, 162, 78, 0.5);"
          >II</span>
          <h3 class="font-display text-2xl tracking-tight text-bone md:text-3xl">Penale</h3>
          <p class="mt-5 font-serif leading-loose text-bone-dim">
            Capacità di intendere e volere, perizie criminologiche.
          </p>
        </article>

        <article
          data-reveal
          tabindex="0"
          class="door border-t px-2 py-12 md:border-l md:border-t-0 md:px-10 md:py-4"
          style="border-color: var(--line)"
        >
          <span
            data-numeral
            aria-hidden="true"
            class="mb-8 block font-secret leading-none"
            style="font-size: clamp(4.5rem, 8vw, 6.5rem); color: rgba(200, 162, 78, 0.5);"
          >III</span>
          <h3 class="font-display text-2xl tracking-tight text-bone md:text-3xl">Forense</h3>
          <p class="mt-5 font-serif leading-loose text-bone-dim">
            Autopsia psicologica, decessi equivoci, scomparse.
          </p>
        </article>

      </div>

      <a data-reveal href="/perizie" class="cta-link mt-14">Tutte le perizie →</a>
    </div>
  </section>


  {/* LE MIE ATTIVITÀ · NEI MEDIA */}
  <section
    id="media"
    class="relative overflow-hidden px-6"
    style="padding-block: var(--space-band)"
  >
    <div class="mx-auto max-w-text">
      <p data-reveal class="eyebrow mb-8">Le mie attività · Nei media</p>
      <h2 data-reveal class="font-display text-3xl leading-tight tracking-tight text-bone md:text-4xl">
        {"L'analisi, non la cronaca.".split(' ').map((w, i, arr) => (
          <Fragment>
            <span class="word">{w}</span>{i < arr.length - 1 ? ' ' : ''}
          </Fragment>
        ))}
      </h2>
      <p data-reveal class="mt-10 font-serif leading-loose text-bone">
        Intervengo nei principali format di approfondimento come criminologa.
        Porto la lettura del comportamento e del movente — mai lo spettacolo
        del dolore.
      </p>

      {/* TODO: outlet diventeranno una content collection (televisione). Per ora hardcoded. */}
      <div data-reveal class="mt-10 flex flex-wrap items-baseline gap-x-8 gap-y-3 font-display text-2xl md:text-3xl">
        <a href="/media/televisione" class="media-outlet">Quarto Grado</a>
        <span class="text-bone-faint" aria-hidden="true">·</span>
        <a href="/media/televisione" class="media-outlet">Pomeriggio Cinque</a>
      </div>

      <a data-reveal href="/media/televisione" class="cta-link mt-12">Tutte le apparizioni →</a>
    </div>
  </section>


  {/* IMPEGNO — affiliazioni istituzionali, voce sobria */}
  <section
    id="affiliazioni"
    class="relative px-6"
    style="padding-block: var(--space-band); background-color: var(--color-ink-2);"
  >
    <div class="mx-auto max-w-wide">
      <p data-reveal class="eyebrow mb-8">Impegno</p>
      <p data-reveal class="max-w-2xl font-serif text-lg leading-loose text-bone md:text-xl">
        Da anni dedico parte del mio tempo a due realtà che riconosco come una
        parte di me: una scuola che forma chi vuole leggere il crimine,
        un'associazione che tiene viva la voce delle famiglie di chi è scomparso.
      </p>

      <div class="mt-16 grid grid-cols-1 gap-12 md:mt-20 md:grid-cols-2 md:gap-x-20 md:gap-y-16">

        <article data-reveal class="affiliazione-block">
          <p class="font-sans text-xs font-semibold uppercase tracking-eyebrow text-gold">
            Presidente
          </p>
          <h3 class="mt-3 font-display text-2xl tracking-tight text-bone md:text-3xl">
            La Scuola di Atene APS
          </h3>
          <p class="mt-5 max-w-md font-serif leading-loose text-bone-dim">
            Associazione di promozione sociale: percorsi formativi in
            criminologia investigativa, psicologia forense, prevenzione della
            violenza.
          </p>
          {/* TODO: confermare URL — risulta https://www.lascuoladiatene.org */}
          <a href="#" class="cta-link mt-6">Visita il sito →</a>
        </article>

        <article data-reveal class="affiliazione-block">
          <p class="font-sans text-xs font-semibold uppercase tracking-eyebrow text-gold">
            Psicologa volontaria
          </p>
          <h3 class="mt-3 font-display text-2xl tracking-tight text-bone md:text-3xl">
            Associazione Penelope Italia
          </h3>
          <p class="mt-5 max-w-md font-serif leading-loose text-bone-dim">
            Associazione nazionale dei familiari di persone scomparse. Sostegno
            psicologico, attivismo, presenza sul territorio.
          </p>
          {/* TODO: confermare URL — risulta https://www.penelopeitalia.org */}
          <a href="#" class="cta-link mt-6">Visita il sito →</a>
        </article>

      </div>
    </div>
  </section>


  {/* ARCHÈ — ponte. Theatre bg (strongest), giant faded "MITO" left, monumental archè h2 */}
  <section
    id="arche-bridge"
    class="arche-bridge relative overflow-hidden px-6"
    style="padding-block: var(--space-band)"
  >
    <div class="absolute inset-0 z-0">
      <Picture
        src={archeTheatre}
        alt=""
        formats={['avif', 'webp']}
        widths={[420, 768, 1280, 1920, 2560]}
        sizes="100vw"
        quality={72}
        loading="lazy"
        class="arche-bg-image h-full w-full object-cover"
      />
      <div
        class="absolute inset-0"
        style="background: linear-gradient(rgba(15,12,7,0.88), rgba(15,12,7,0.55));"
      ></div>
      {/* Gold glow bottom-left */}
      <div
        class="arche-glow absolute inset-0"
        aria-hidden="true"
      ></div>
      <div data-curtain-veil aria-hidden="true" class="absolute inset-0" style="background-color: #0F0C07;"></div>
    </div>

    {/* Giant faded MITO, bleeding off left */}
    <span
      aria-hidden="true"
      class="pointer-events-none absolute -left-6 -top-2 z-10 select-none font-secret italic leading-none md:-left-20 md:top-16"
      style="font-size: clamp(3.5rem, 14vw, 14rem); color: rgba(200, 162, 78, 0.07);"
    >MITO</span>

    <div class="relative z-20 mx-auto max-w-text text-center">
      <p data-reveal class="eyebrow mb-10">Il progetto editoriale</p>

      <h2
        data-reveal
        class="vt-arche-heading font-display tracking-tight text-bone"
        style="font-size: clamp(3.5rem, 12vw, 11rem); line-height: 0.92; letter-spacing: -0.02em;"
      >archè</h2>

      <p data-reveal class="mt-4 font-secret text-xl italic text-bone-dim md:text-2xl">
        dal mito alla mente
      </p>

      <p data-reveal class="mx-auto mt-12 max-w-md font-serif leading-loose text-bone">
        Ogni crimine contemporaneo ripete una scena già scritta. Il progetto
        con cui restituisco al crimine la sua origine — dove tutto comincia.
      </p>

      <a
        data-reveal
        href="/arche"
        class="mt-14 inline-block bg-gold px-9 py-4 font-sans text-sm font-semibold uppercase tracking-eyebrow text-ink transition hover:bg-gold-bright"
      >
        Scopri archè
      </a>
    </div>
  </section>

  </main>


  {/* Hash legacy → redirect lato client */}
  <script is:inline>
    (function () {
      const map = {
        '#lamiastoria': '/storia',
        '#ilmiolavoro': '/metodo',
        '#lemieattività': '/media',
        '#lemieattivita': '/media',
        '#contattami': '/contatti',
      };
      const target = map[decodeURIComponent(window.location.hash)];
      if (target) window.location.replace(target);
    })();
  </script>

  {/* Motion runtime is imported once in Base.astro */}


  <style>
    /* ===== Background image treatments — archè palette ===== */
    .hero-bg-image {
      filter: brightness(0.55) sepia(0.22) contrast(1.05);
    }
    .lavoro-bg-image {
      filter: brightness(0.32) sepia(0.45) saturate(0.7) blur(1px);
    }
    .arche-bg-image {
      filter: brightness(0.5) sepia(0.32) contrast(1.08);
    }

    /* Portrait frame on rich background — empty editorial frame, gold hairline */
    .portrait-frame {
      background-color: rgba(20, 17, 12, 0.55);
      border: 1px solid var(--line);
    }

    /* Drop cap on the storia anticipo lead */
    .home-storia-lead::first-letter {
      font-family: var(--font-display);
      font-weight: 600;
      color: var(--color-gold);
      font-size: 3.6em;
      line-height: 0.95;
      float: left;
      padding-right: 0.14em;
      padding-top: 0.06em;
      margin-bottom: -0.05em;
    }

    /* Editorial CTA */
    .cta-link {
      display: inline-block;
      color: var(--color-gold);
      font-family: var(--font-sans);
      font-size: var(--fs-sm);
      font-weight: 600;
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      border-bottom: 1px solid var(--color-gold);
      padding-bottom: 0.35em;
      transition: color 250ms ease, border-color 250ms;
    }
    .cta-link:hover { color: var(--color-gold-bright); border-color: var(--color-gold-bright); }

    /* Outlet TV: Bodoni con sottolineatura oro */
    .media-outlet {
      color: var(--color-bone);
      text-decoration: underline;
      text-decoration-color: var(--color-gold);
      text-underline-offset: 0.22em;
      text-decoration-thickness: 1px;
      transition: color 220ms, text-decoration-color 220ms;
    }
    .media-outlet:hover { color: var(--color-gold-bright); text-decoration-color: var(--color-gold-bright); }

    /* ===== Three doors — calmed hover, no scale, gentle dim ===== */
    .lavoro-doors .door {
      outline: none;
      cursor: default;
      transition: opacity 320ms ease, background-color 320ms ease;
    }
    .lavoro-doors .door [data-numeral] {
      transition: color 320ms ease;
    }

    @media (hover: hover) and (pointer: fine) {
      .lavoro-doors:has(.door:hover) .door:not(:hover) { opacity: 0.85; }
      .lavoro-doors .door:hover { background-color: var(--color-ink-2); }
      .lavoro-doors .door:hover [data-numeral] { color: rgba(200, 162, 78, 0.85); }
    }
    .lavoro-doors:has(.door:focus-visible) .door:not(:focus-visible) { opacity: 0.85; }
    .lavoro-doors .door:focus-visible {
      background-color: var(--color-ink-2);
      outline: 1px solid var(--color-gold);
      outline-offset: 6px;
    }
    .lavoro-doors .door:focus-visible [data-numeral] { color: rgba(200, 162, 78, 0.85); }

    /* Archè bridge: solid base color underneath the picture */
    .arche-bridge { background-color: #0F0C07; }
    .arche-glow {
      background: radial-gradient(ellipse 75vw 65vh at 0% 100%, rgba(200, 162, 78, 0.12), transparent 62%);
    }
  </style>

</Base>
