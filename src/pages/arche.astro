---
import Base from '../layouts/Base.astro';
---

<Base
  title="archè"
  description="Dal mito alla mente. Il progetto editoriale con cui Gabriella Marano restituisce al crimine la sua origine."
>
  <section
    class="arche-bridge relative overflow-hidden px-6"
    style="padding-block: var(--space-band);"
  >
    <div
      aria-hidden="true"
      class="arche-glow pointer-events-none absolute inset-0"
    ></div>

    <div class="relative mx-auto max-w-text text-center">
      <p class="eyebrow mb-10">Il progetto editoriale</p>

      <h2
        class="vt-arche-heading font-display tracking-tight text-bone"
        style="font-size: clamp(4rem, 9vw, 7rem); line-height: 0.95; letter-spacing: -0.015em;"
      >archè</h2>

      <p class="mt-4 font-secret text-xl italic text-bone-dim md:text-2xl">
        Dal mito alla mente.
      </p>

      <p class="mx-auto mt-14 max-w-md font-serif leading-loose text-bone">
        Pagina in costruzione — landing ponte verso archecrime.com.
      </p>
    </div>
  </section>

  <style>
    .arche-bridge { background-color: #0F0C07; }
    .arche-glow {
      background: radial-gradient(ellipse 75vw 65vh at 0% 100%, rgba(200, 162, 78, 0.12), transparent 62%);
    }
  </style>
</Base>
