---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';

type CollectionType = 'televisione' | 'scrittura' | 'formazione' | 'incontri';

export async function getStaticPaths() {
  const collections: CollectionType[] = ['televisione', 'scrittura', 'formazione', 'incontri'];
  const paths = [];
  for (const type of collections) {
    const entries = await getCollection(type);
    for (const e of entries) {
      paths.push({
        params: { type, slug: e.slug },
        props: { entry: e, type, allEntries: entries },
      });
    }
  }
  return paths;
}

interface Props {
  entry: CollectionEntry<CollectionType>;
  type: CollectionType;
  allEntries: CollectionEntry<CollectionType>[];
}

const { entry, type, allEntries } = Astro.props as Props;
const { Content } = await entry.render();

const fmtFull = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
const fmtMonthYear = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { month: 'long', year: 'numeric' }).format(d);

const TYPE_LABEL: Record<CollectionType, string> = {
  televisione: 'Televisione',
  scrittura: 'Scrittura',
  formazione: 'Formazione',
  incontri: 'Incontri',
};

const CTA: Record<CollectionType, string> = {
  televisione: 'Vedi il contributo →',
  scrittura: 'Vai alla pubblicazione →',
  formazione: 'Maggiori informazioni →',
  incontri: 'Dettagli evento →',
};

const PLACEHOLDER: Record<CollectionType, string> = {
  televisione: 'T',
  scrittura: 'L',
  formazione: 'F',
  incontri: 'I',
};

const related = allEntries
  .filter((e) => e.slug !== entry.slug)
  .sort((a, b) => +b.data.date - +a.data.date)
  .slice(0, 2);
---

<Base
  title={entry.data.title}
  description={entry.data.summary}
  ogImage={entry.data.cover}
>
  <main id="main" class="relative">

    {/* INTRO band — eyebrow breadcrumb + unearth title */}
    <section class="relative px-6" style="padding-block: var(--space-band)">
      <div class="mx-auto max-w-text">
        <p data-page-entry class="entry-breadcrumb mb-8">
          <a href="/media">Le mie attività</a>
          <span aria-hidden="true">·</span>
          <a href={`/media/${type}`} class="entry-breadcrumb-current">{TYPE_LABEL[type]}</a>
        </p>

        <h2
          data-unearth-hero
          data-vary
          class="font-display tracking-tight text-bone"
          style="font-size: clamp(2rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.012em;"
        >
          {entry.data.title.split(' ').map((w, i, arr) => (
            <Fragment>
              <span class="word">{w}</span>{i < arr.length - 1 ? ' ' : ''}
            </Fragment>
          ))}
        </h2>
        <div data-ground-line aria-hidden="true" class="ground-line"></div>

        <p data-page-entry class="mt-10 entry-meta">
          <time datetime={entry.data.date.toISOString()} class="entry-date">{fmtFull(entry.data.date)}</time>
          {(entry.data.outlet || entry.data.publisher) && (
            <Fragment>
              <span class="entry-meta-sep" aria-hidden="true">·</span>
              <span class="entry-outlet">{entry.data.outlet || entry.data.publisher}</span>
            </Fragment>
          )}
        </p>
      </div>
    </section>

    {/* COVER (if present) — full-bleed framed */}
    {entry.data.cover ? (
      <section class="relative px-6">
        <div data-reveal class="mx-auto max-w-wide detail-cover">
          <img src={entry.data.cover} alt={entry.data.coverAlt ?? entry.data.title} loading="eager" />
        </div>
      </section>
    ) : (
      <section class="relative px-6">
        <div data-reveal class="mx-auto max-w-wide detail-cover detail-cover-placeholder" aria-hidden="true">
          <span>{PLACEHOLDER[type]}</span>
        </div>
      </section>
    )}

    {/* MDX body */}
    <section class="relative px-6" style="padding-block: var(--space-band)">
      <div class="mx-auto max-w-text mdx-prose">
        <Content />
      </div>
    </section>

    {/* EXTERNAL LINK + back nav */}
    <section class="relative px-6" style="padding-block: 0 var(--space-band)">
      <div class="mx-auto max-w-text">
        <div data-reveal class="detail-actions">
          {entry.data.externalUrl && (
            <a href={entry.data.externalUrl} target="_blank" rel="noopener noreferrer" class="cta-link">
              {CTA[type]}
            </a>
          )}
          <a href={`/media/${type}`} class="cta-link cta-link-secondary">
            ← Torna a {TYPE_LABEL[type]}
          </a>
        </div>
      </div>
    </section>

    {/* RELATED — other entries from the same collection */}
    {related.length > 0 && (
      <section class="relative px-6" style="padding-block: var(--space-band); background-color: var(--color-ink-2)">
        <div class="mx-auto max-w-wide">
          <p data-reveal class="eyebrow mb-12">Continua a leggere</p>
          <ul class="entries-list">
            {related.map((e) => (
              <li data-reveal class="entry">
                <a href={`/media/${type}/${e.slug}`} class="entry-cover-link" aria-label={`Apri: ${e.data.title}`}>
                  <div class="entry-cover">
                    {e.data.cover ? (
                      <img src={e.data.cover} alt={e.data.coverAlt ?? ''} loading="lazy" />
                    ) : (
                      <div class="entry-cover-placeholder" aria-hidden="true">
                        <span>{PLACEHOLDER[type]}</span>
                      </div>
                    )}
                  </div>
                </a>
                <div class="entry-body">
                  <p class="entry-meta">
                    <time datetime={e.data.date.toISOString()} class="entry-date">{fmtMonthYear(e.data.date)}</time>
                    {(e.data.outlet || e.data.publisher) && (
                      <Fragment>
                        <span class="entry-meta-sep" aria-hidden="true">·</span>
                        <span class="entry-outlet">{e.data.outlet || e.data.publisher}</span>
                      </Fragment>
                    )}
                  </p>
                  <h3 class="entry-title">
                    <a href={`/media/${type}/${e.slug}`}>{e.data.title}</a>
                  </h3>
                  <p class="entry-summary">{e.data.summary}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

  </main>

  <style>
    .entry-breadcrumb {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5em 0.6em;
      align-items: baseline;
    }
    .entry-breadcrumb a {
      color: var(--color-bone-dim);
      text-decoration: none;
      transition: color 240ms;
    }
    .entry-breadcrumb a:hover { color: var(--color-gold-bright); }
    .entry-breadcrumb-current { color: var(--color-gold) !important; }
    .entry-breadcrumb span { color: var(--color-bone-faint); opacity: 0.6; }

    .detail-cover {
      border: 1px solid var(--line);
      overflow: hidden;
    }
    .detail-cover img {
      width: 100%;
      height: auto;
      display: block;
    }
    .detail-cover-placeholder {
      aspect-ratio: 16 / 9;
      background: linear-gradient(180deg, var(--color-ink-3) 0%, var(--color-ink-2) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .detail-cover-placeholder span {
      font-family: var(--font-secret);
      font-style: italic;
      font-size: clamp(6rem, 14vw, 12rem);
      color: rgba(200, 162, 78, 0.28);
      line-height: 1;
    }

    /* MDX body styling — long-form editorial reading */
    .mdx-prose {
      font-family: var(--font-serif);
      color: var(--color-bone);
      line-height: 1.78;
    }
    .mdx-prose > * + * { margin-top: 1.4em; }
    .mdx-prose p {
      font-size: clamp(1rem, 1.1vw, 1.1rem);
      margin: 0;
    }
    .mdx-prose strong { color: var(--color-bone); font-weight: 600; }
    .mdx-prose em { font-style: italic; }
    .mdx-prose a {
      color: var(--color-gold);
      text-decoration: underline;
      text-underline-offset: 0.22em;
      text-decoration-color: rgba(200, 162, 78, 0.5);
      transition: color 220ms, text-decoration-color 220ms;
    }
    .mdx-prose a:hover {
      color: var(--color-gold-bright);
      text-decoration-color: var(--color-gold-bright);
    }
    .mdx-prose h2, .mdx-prose h3 {
      font-family: var(--font-display);
      color: var(--color-bone);
      line-height: 1.2;
      letter-spacing: -0.005em;
      margin-top: 2em;
    }
    .mdx-prose h2 { font-size: clamp(1.5rem, 2vw, 1.8rem); }
    .mdx-prose h3 { font-size: clamp(1.2rem, 1.6vw, 1.45rem); }
    .mdx-prose ul, .mdx-prose ol {
      padding-left: 1.5em;
      list-style-position: outside;
    }
    .mdx-prose ul { list-style: none; padding-left: 0; }
    .mdx-prose ul li {
      position: relative;
      padding-left: 1.5em;
      margin-bottom: 0.5em;
    }
    .mdx-prose ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--color-gold);
    }
    .mdx-prose blockquote {
      font-style: italic;
      padding-left: 1.5em;
      border-left: 1px solid var(--color-gold);
      color: var(--color-bone);
    }

    /* Actions */
    .detail-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem 3rem;
      align-items: baseline;
    }
    .cta-link {
      display: inline-block;
      color: var(--color-gold);
      font-family: var(--font-sans);
      font-size: var(--fs-sm);
      font-weight: 600;
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      border-bottom: 1px solid var(--color-gold);
      padding-bottom: 0.35em;
      text-decoration: none;
      transition: color 240ms, border-color 240ms;
    }
    .cta-link:hover { color: var(--color-gold-bright); border-color: var(--color-gold-bright); }
    .cta-link-secondary {
      color: var(--color-bone-dim);
      border-bottom-color: rgba(200, 162, 78, 0.4);
    }
    .cta-link-secondary:hover { color: var(--color-bone); border-bottom-color: var(--color-gold-bright); }

    .entry-cover-link { display: block; text-decoration: none; }
    .entry-title a { color: inherit; text-decoration: none; transition: color 240ms; }
    .entry-title a:hover { color: var(--color-gold-bright); }
  </style>
</Base>
