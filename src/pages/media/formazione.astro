---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('formazione');
const sorted = entries.sort((a, b) => +b.data.date - +a.data.date);

const fmtMonthYear = (d: Date) =>
  new Intl.DateTimeFormat('it-IT', { month: 'long', year: 'numeric' }).format(d);
---

<Base
  title="Formazione"
  description="Corsi, percorsi formativi e collaborazioni con scuole ed enti."
>
  <main id="main" class="relative">

    <section class="relative px-6" style="padding-block: var(--space-band)">
      <div class="mx-auto max-w-text">
        <p data-page-entry class="eyebrow mb-8">Le mie attività · Formazione</p>
        <h2
          data-unearth-hero
          class="font-display tracking-tight text-bone"
          style="font-size: clamp(2.25rem, 6vw, 4.5rem); line-height: 1.0; letter-spacing: -0.012em;"
        >
          {"Corsi e percorsi.".split(' ').map((w, i, arr) => (
            <Fragment>
              <span class="word">{w}</span>{i < arr.length - 1 ? ' ' : ''}
            </Fragment>
          ))}
        </h2>
        <div data-ground-line aria-hidden="true" class="ground-line"></div>
        <p data-page-entry class="mt-10 font-serif leading-loose text-bone">
          Percorsi formativi con La Scuola di Atene e collaborazioni con
          scuole, enti e istituzioni. Formo chi vuole leggere il crimine,
          chi indaga, chi educa.
        </p>
      </div>
    </section>

    <section class="px-6" style="padding-block: var(--space-band)">
      <div class="mx-auto max-w-wide">
        {sorted.length === 0 ? (
          <div class="empty-state mx-auto max-w-md py-16 text-center">
            <p class="mb-4 font-sans text-xs font-semibold uppercase tracking-eyebrow text-gold">Archivio</p>
            <p class="font-serif italic leading-loose text-bone-dim">
              In aggiornamento. I percorsi verranno elencati progressivamente.
            </p>
          </div>
        ) : (
          <ul class="entries-list">
            {sorted.map((e) => (
              <li data-reveal class="entry">
                <div class="entry-cover">
                  {e.data.cover ? (
                    <img src={e.data.cover} alt={e.data.coverAlt ?? ''} loading="lazy" />
                  ) : (
                    <div class="entry-cover-placeholder" aria-hidden="true">
                      <span>F</span>
                    </div>
                  )}
                </div>
                <div class="entry-body">
                  <p class="entry-meta">
                    <time datetime={e.data.date.toISOString()} class="entry-date">{fmtMonthYear(e.data.date)}</time>
                    {(e.data.outlet || e.data.publisher) && (
                      <Fragment>
                        <span class="entry-meta-sep" aria-hidden="true">·</span>
                        <span class="entry-outlet">{e.data.outlet || e.data.publisher}</span>
                      </Fragment>
                    )}
                  </p>
                  <h3 class="entry-title">{e.data.title}</h3>
                  <p class="entry-summary">{e.data.summary}</p>
                  {e.data.externalUrl && (
                    <a href={e.data.externalUrl} target="_blank" rel="noopener noreferrer" class="entry-link">
                      Maggiori informazioni →
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>

  </main>
</Base>
