---
import Base from '../layouts/Base.astro';

const principi = [
  {
    num: 'I',
    title: 'Osservare',
    body:
      "Mi muovo piano, tra i dettagli. Guardo chi sposta lo sguardo altrove, perché è lì che spesso si nasconde ciò che conta. Osservare non è guardare: è raccogliere senza toccare.",
  },
  {
    num: 'II',
    title: 'Ricostruire',
    body:
      "Unisco i punti, ritrovo i fili. Un fatto umano è una trama interrotta. Ricostruire significa rimettere insieme i frammenti senza inventare ciò che manca, distinguendo il dato dall'interpretazione.",
  },
  {
    num: 'III',
    title: 'Restituire',
    body:
      "Tra le mani non ho mai un caso, ma una persona. Il lavoro finisce quando ciò che ho ricostruito torna utile — a un giudice, a una famiglia, a chi studia perché non accada di nuovo.",
  },
];
---

<Base
  title="Metodo"
  description="Osservare, ricostruire, restituire. I tre movimenti che governano ogni perizia, ogni consulenza, ogni lettura del comportamento."
>
  <main class="relative">

    {/* Subtle ambient glow — same family as the home */}
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0"
      style="background: radial-gradient(ellipse 70vw 55vh at 0% 100%, rgba(200, 162, 78, 0.055), transparent 62%);"
    ></div>

    {/* INTRO band with giant faded ghost word */}
    <section
      class="relative overflow-hidden px-6"
      style="padding-block: var(--space-band)"
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -right-6 -top-2 z-0 select-none font-secret italic leading-none md:-right-24 md:top-16"
        style="font-size: clamp(3.5rem, 14vw, 14rem); color: rgba(200, 162, 78, 0.05);"
      >RESTITUIRE</span>

      <div class="relative z-10 mx-auto max-w-text">
        <p data-page-entry class="eyebrow mb-8">Il modo in cui lavoro</p>
        <h2
          data-page-entry
          class="font-display tracking-tight text-bone"
          style="font-size: clamp(2.25rem, 7vw, 5.5rem); line-height: 0.95; letter-spacing: -0.015em;"
        >Osservare, ricostruire, restituire.</h2>
        <p data-page-entry class="mt-10 font-serif leading-loose text-bone">
          Lavoro su ciò che resta. Su una traccia, un comportamento, una
          parola non detta. Il mio mestiere non è giudicare per primo:
          è ricomporre con cura, finché i fatti tornano a parlare.
          Tre movimenti, sempre gli stessi.
        </p>
      </div>
    </section>

    {/* Composed divider — same vocabulary as /storia */}
    <div
      class="relative mx-auto flex max-w-wide items-center justify-center px-6"
      style="padding-block: clamp(2rem, 5vw, 4rem);"
      aria-hidden="true"
    >
      <span class="block h-px w-16 md:w-28" style="background-color: var(--line)"></span>
      <span class="mx-5 inline-block h-2 w-2 rotate-45" style="background-color: var(--color-gold)"></span>
      <span class="block h-px w-16 md:w-28" style="background-color: var(--line)"></span>
    </div>

    {/* THREE PRINCIPLES — vertical editorial sequence */}
    <section class="relative px-6" style="padding-block: var(--space-band)">
      <div class="mx-auto flex max-w-wide flex-col gap-y-24 md:gap-y-32">

        {principi.map((p, idx) => (
          <article
            data-reveal
            class={`relative grid grid-cols-1 items-start gap-x-12 gap-y-6 md:grid-cols-[auto_1fr] md:gap-x-20 ${idx > 0 ? 'pt-16 md:pt-24' : ''}`}
          >
            {idx > 0 && (
              <span
                aria-hidden="true"
                class="absolute left-0 right-0 top-0 h-px md:left-12 md:right-12"
                style="background-color: var(--line)"
              ></span>
            )}

            <span
              aria-hidden="true"
              class="font-secret leading-none"
              style="font-size: clamp(5rem, 11vw, 9rem); color: rgba(200, 162, 78, 0.5);"
            >{p.num}</span>

            <div class="max-w-text">
              <h3
                class="font-display tracking-tight text-bone"
                style="font-size: clamp(2.25rem, 4.5vw, 3.5rem); line-height: 1.0;"
              >{p.title}</h3>
              <p class="mt-6 font-serif leading-loose text-bone">{p.body}</p>
            </div>
          </article>
        ))}

      </div>
    </section>

  </main>
</Base>
