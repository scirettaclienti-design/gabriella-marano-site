---
import '../styles/tailwind.css';
import '@arche/tokens';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
}

const { title, description, ogImage, bodyClass = '' } = Astro.props;
const fullTitle = `${title} — Gabriella Marano`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta
      property="og:image"
      content={new URL(ogImage ?? '/og.jpg', Astro.site).toString()}
    />
    <meta property="og:image:width" content="1050" />
    <meta property="og:image:height" content="1180" />
    <meta property="og:locale" content="it_IT" />
    <meta name="twitter:image" content={new URL(ogImage ?? '/og.jpg', Astro.site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}

    <ViewTransitions />

    {/*
      Pre-hide motion targets BEFORE first paint, but only when motion is
      enabled and this is the first home view of the session. Removed by
      motion JS once timelines are armed, or by a 5s safety net below.
    */}
    <script is:inline>
      (function () {
        try {
          var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!noMotion) {
            document.documentElement.classList.add('js-motion');
            if (!sessionStorage.getItem('homeOpeningSeen')) {
              document.documentElement.classList.add('js-opening-pending');
            }
          }
        } catch (e) {}
      })();
    </script>

    {/*
      Pre-hide CSS shipped INLINE in <head> so it applies at first paint
      in dev mode too (where <style is:global> would be loaded via JS).
      Same rules duplicated below in <style is:global> for prod consistency.
    */}
    <style is:inline>
      /* Skip link a11y — hidden by default, visible on focus */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--color-gold);
        color: var(--color-ink);
        padding: 0.7rem 1.2rem;
        font-family: var(--font-sans);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        z-index: 100;
        transition: top 180ms ease;
      }
      .skip-link:focus { top: 0; outline: 0; }

      /* Plain reveals (non-word [data-reveal] / [data-page-entry]) */
      .js-motion [data-reveal] { opacity: 0; transform: translateY(56px); }
      .js-motion [data-page-entry] { opacity: 0; transform: translateY(56px); }
      .js-motion [data-reveal]:has(.word),
      .js-motion [data-page-entry]:has(.word),
      .js-motion [data-unearth-hero] { opacity: 1; transform: none; }

      /* Stratigraphic word unearth pre-state.
         Only clip-path here — it alone hides the word at first paint.
         GSAP layers the rest (blur, tracking, opacity) inline at set(). */
      .js-motion .word {
        display: inline-block;
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        will-change: clip-path, filter;
      }

      /* Ground line — drawn from left, fades to resting low opacity */
      .ground-line {
        display: block;
        height: 1px;
        width: 5rem;
        background-color: var(--color-gold);
        margin-top: 0.7em;
        transform: scaleX(1);
        transform-origin: left center;
        opacity: 0.25;
      }
      .ground-line.is-centered { margin-left: auto; margin-right: auto; transform-origin: center center; }
      .js-motion .ground-line { transform: scaleX(0); opacity: 0.9; will-change: transform, opacity; }

      /* Hero background image — clip wipe in sync with the title */
      .js-motion [data-unearth-bg] {
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        will-change: clip-path;
      }

      /* Section bg veil (lavoro paper on home, archè bridge on home) */
      .js-motion [data-curtain-veil] { transform: scaleY(1); transform-origin: top center; will-change: transform; }

      /* Home opening — support elements (eyebrow, lead, scroll-hint, portrait) */
      .js-opening-pending #hero-portrait,
      .js-opening-pending #hero-eyebrow,
      .js-opening-pending #hero-lead,
      .js-opening-pending #hero-scroll-hint { opacity: 0; will-change: opacity; }
    </style>

    <slot name="head" />
  </head>
  <body class:list={['bg-ink text-bone font-body antialiased', bodyClass]}>
    <a href="#main" class="skip-link">Salta al contenuto</a>
    <Header />
    <slot />
    <Footer />

    {/* Motion runtime — runs site-wide so /storia, /metodo, /perizie, /arche
        all get the calm scroll-reveal. Hero opening only fires on the home. */}
    <script>
      import '../scripts/home-motion';
    </script>

    {/* Safety net: only fires if motion JS never loaded.
        The motion script clears window.__motionSafety on init. */}
    <script is:inline>
      window.__motionSafety = setTimeout(function () {
        document.documentElement.classList.remove('js-opening-pending');
        document.documentElement.classList.remove('js-motion');
      }, 5000);
    </script>
  </body>
</html>

<style is:global>
  /* View Transition name-match: the archè title morphs from the home
     bridge into the /arche page hero; the storia title morphs from the
     home anticipo into the /storia page hero. No white flash. */
  .vt-arche-heading { view-transition-name: arche-heading; }
  .vt-storia-heading { view-transition-name: storia-heading; }

  /* The authoritative pre-hide CSS lives in <style is:inline> above so it
     applies before first paint in both dev and prod. Rules below remain
     for safety; they mirror the inline ones. */
  .js-motion [data-reveal] { opacity: 0; transform: translateY(56px); }
  .js-motion [data-page-entry] { opacity: 0; transform: translateY(56px); }
  .js-motion [data-reveal]:has(.word),
  .js-motion [data-page-entry]:has(.word),
  .js-motion [data-unearth-hero] { opacity: 1; transform: none; }
  .js-motion .word {
    display: inline-block;
    clip-path: inset(0 0 100% 0);
    -webkit-clip-path: inset(0 0 100% 0);
  }
  .js-motion [data-unearth-bg] {
    clip-path: inset(0 0 100% 0);
    -webkit-clip-path: inset(0 0 100% 0);
  }
  .js-motion [data-curtain-veil] { transform: scaleY(1); transform-origin: top center; }

  /* Pre-hide for the opening reveal — unused but kept for back-compat. */
  .js-opening-pending .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    will-change: transform, opacity;
  }
  .js-opening-pending .hero-bg-image {
    transform: scale(1.08);
    will-change: transform;
  }
  .js-opening-pending #hero-portrait {
    opacity: 0;
    will-change: opacity;
  }
  .js-opening-pending #hero-eyebrow,
  .js-opening-pending #hero-lead,
  .js-opening-pending #hero-scroll-hint {
    opacity: 0;
    will-change: opacity;
  }

  /* Disable any view-transition animation when the user opts out */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) { animation: none !important; }
  }

  /* ===== ENTRIES LIST — editorial archive cards =====
     Used by /media/televisione /scrittura /formazione /incontri.
     Each entry is a card with a cover area on the left (real image
     if set in frontmatter, else a tasteful placeholder) and the
     metadata + body on the right. */
  .entries-list { list-style: none; padding: 0; margin: 0; }
  .entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--line);
    transition: padding 240ms ease;
  }
  .entry:last-child { border-bottom: 1px solid var(--line); }

  @media (min-width: 640px) {
    .entry { grid-template-columns: 11rem 1fr; gap: 2.25rem; padding: 2.75rem 0; }
  }
  @media (min-width: 1024px) {
    .entry { grid-template-columns: 13rem 1fr; gap: 3rem; padding: 3rem 0; }
  }

  /* COVER — square frame, holds either a real image or a placeholder mark */
  .entry-cover {
    position: relative;
    aspect-ratio: 3 / 4;
    background-color: var(--color-ink-3);
    border: 1px solid var(--line);
    overflow: hidden;
    transition: border-color 280ms ease, transform 280ms ease;
    max-width: 11rem;
  }
  @media (min-width: 640px) { .entry-cover { max-width: none; } }
  .entry-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .entry-cover-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, var(--color-ink-3) 0%, var(--color-ink-2) 100%);
  }
  .entry-cover-placeholder span {
    font-family: var(--font-secret);
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: rgba(200, 162, 78, 0.32);
    line-height: 1;
  }
  .entry:hover .entry-cover { border-color: rgba(200, 162, 78, 0.45); }

  /* META — date + outlet on one line, uppercase eyebrow style */
  .entry-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5em 0.8em;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
  }
  .entry-date { color: var(--color-gold); }
  .entry-meta-sep { color: var(--color-bone-faint); opacity: 0.6; }
  .entry-outlet { color: var(--color-bone-dim); }

  .entry-title {
    margin: 0.7em 0 0;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2.4vw, 2rem);
    line-height: 1.18;
    letter-spacing: -0.005em;
    color: var(--color-bone);
  }
  .entry-summary {
    margin: 0.85em 0 0;
    font-family: var(--font-serif);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.7;
    color: var(--color-bone-dim);
    max-width: var(--col-text);
  }
  .entry-actions {
    margin-top: 1.5em;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7em 2em;
    align-items: baseline;
  }
  .entry-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--color-gold);
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 0.35em;
    text-decoration: none;
    transition: color 250ms, border-color 250ms;
  }
  .entry-link:hover { color: var(--color-gold-bright); border-bottom-color: var(--color-gold-bright); }
  .entry-link:focus-visible { outline: 1px solid var(--color-gold); outline-offset: 4px; }
  .entry-link-external {
    color: var(--color-bone-dim);
    border-bottom-color: rgba(200, 162, 78, 0.4);
  }
  .entry-link-external:hover { color: var(--color-bone); border-bottom-color: var(--color-gold-bright); }

  .entry-cover-link { display: block; text-decoration: none; }
  .entry-title a { color: inherit; text-decoration: none; transition: color 240ms; }
  .entry-title a:hover { color: var(--color-gold-bright); }

  /* ===== LIGHT PAGE — warm bone bg (#F2EAD3) + ink text — /perizie ===== */
  body.is-light-page { background-color: #F2EAD3; color: var(--color-ink); }
  body.is-light-page .site-header { color: var(--color-ink); }
  body.is-light-page .site-header.is-scrolled {
    background-color: rgba(242, 234, 211, 0.88);
    border-bottom-color: rgba(140, 110, 54, 0.3);
  }
  body.is-light-page .site-header .wordmark,
  body.is-light-page .site-header .nav-link { color: var(--color-ink); }
  body.is-light-page .site-header .nav-link:hover { color: var(--color-gold-deep); }
  body.is-light-page .site-header .nav-link.is-active {
    color: var(--color-gold-deep);
    border-bottom-color: var(--color-gold-deep);
  }
  body.is-light-page .site-header .arche-marker { color: var(--color-gold-deep); }
  body.is-light-page .site-header .arche-marker:hover { color: var(--color-gold); }
  body.is-light-page .site-header .mobile-toggle span { background: var(--color-ink); }
</style>
