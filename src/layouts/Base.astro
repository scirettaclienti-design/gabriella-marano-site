---
import '../styles/tailwind.css';
import '@arche/tokens';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const fullTitle = `${title} — Gabriella Marano`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}

    <ViewTransitions />

    {/*
      Pre-hide motion targets BEFORE first paint, but only when motion is
      enabled and this is the first home view of the session. Removed by
      motion JS once timelines are armed, or by a 5s safety net below.
    */}
    <script is:inline>
      (function () {
        try {
          var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!noMotion) {
            document.documentElement.classList.add('js-motion');
            if (!sessionStorage.getItem('homeOpeningSeen')) {
              document.documentElement.classList.add('js-opening-pending');
            }
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="bg-ink text-bone font-body antialiased">
    <slot />

    {/* Motion runtime — runs site-wide so /storia, /metodo, /perizie, /arche
        all get the calm scroll-reveal. Hero opening only fires on the home. */}
    <script>
      import '../scripts/home-motion';
    </script>

    {/* Safety net: only fires if motion JS never loaded.
        The motion script clears window.__motionSafety on init. */}
    <script is:inline>
      window.__motionSafety = setTimeout(function () {
        document.documentElement.classList.remove('js-opening-pending');
        document.documentElement.classList.remove('js-motion');
      }, 5000);
    </script>
  </body>
</html>

<style is:global>
  /* MOVE 6 — name-match morph DISABLED.
     <ViewTransitions /> stays active (default cross-fade, no white flash).
     Re-enable by uncommenting these two rules. */
  /*
  .vt-arche-heading { view-transition-name: arche-heading; }
  .vt-storia-heading { view-transition-name: storia-heading; }
  */

  /* Pre-hide for scroll-reveal so elements don't flash visible before JS arms.
     Only when motion is enabled. */
  .js-motion [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
  }
  /* Page-entry title block — a beefier version, fires immediately at page load. */
  .js-motion [data-page-entry] {
    opacity: 0;
    transform: translateY(28px);
  }
  /* Curtain wipe on images — uncovered top-to-bottom when GSAP plays. */
  .js-motion [data-curtain] {
    clip-path: inset(0 0 100% 0);
    -webkit-clip-path: inset(0 0 100% 0);
  }

  /* Pre-hide for the opening reveal (only when .js-opening-pending is set). */
  .js-opening-pending .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    will-change: transform, opacity;
  }
  .js-opening-pending .hero-bg-image {
    transform: scale(1.08);
    will-change: transform;
  }
  .js-opening-pending #hero-portrait {
    opacity: 0;
    will-change: opacity;
  }
  .js-opening-pending #hero-eyebrow,
  .js-opening-pending #hero-lead,
  .js-opening-pending #hero-scroll-hint {
    opacity: 0;
    will-change: opacity;
  }

  /* Disable any view-transition animation when the user opts out */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) { animation: none !important; }
  }
</style>
