---
import '../styles/tailwind.css';
import '@arche/tokens';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const fullTitle = `${title} — Gabriella Marano`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}

    <ViewTransitions />

    {/*
      Pre-hide motion targets BEFORE first paint, but only when motion is
      enabled and this is the first home view of the session. Removed by
      motion JS once timelines are armed, or by a 5s safety net below.
    */}
    <script is:inline>
      (function () {
        try {
          var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!noMotion) {
            document.documentElement.classList.add('js-motion');
            if (!sessionStorage.getItem('homeOpeningSeen')) {
              document.documentElement.classList.add('js-opening-pending');
            }
          }
        } catch (e) {}
      })();
    </script>

    {/*
      Pre-hide CSS shipped INLINE in <head> so it applies at first paint
      in dev mode too (where <style is:global> would be loaded via JS).
      Same rules duplicated below in <style is:global> for prod consistency.
    */}
    <style is:inline>
      /* Plain reveals (non-word [data-reveal] / [data-page-entry]) */
      .js-motion [data-reveal] { opacity: 0; transform: translateY(56px); }
      .js-motion [data-page-entry] { opacity: 0; transform: translateY(56px); }
      .js-motion [data-reveal]:has(.word),
      .js-motion [data-page-entry]:has(.word),
      .js-motion [data-unearth-hero] { opacity: 1; transform: none; }

      /* Stratigraphic word unearth pre-state.
         Only clip-path here — it alone hides the word at first paint.
         GSAP layers the rest (blur, tracking, opacity) inline at set(). */
      .js-motion .word {
        display: inline-block;
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        will-change: clip-path, filter;
      }

      /* Ground line — drawn from left, fades to resting low opacity */
      .ground-line {
        display: block;
        height: 1px;
        width: 5rem;
        background-color: var(--color-gold);
        margin-top: 0.7em;
        transform: scaleX(1);
        transform-origin: left center;
        opacity: 0.25;
      }
      .ground-line.is-centered { margin-left: auto; margin-right: auto; transform-origin: center center; }
      .js-motion .ground-line { transform: scaleX(0); opacity: 0.9; will-change: transform, opacity; }

      /* Hero background image — clip wipe in sync with the title */
      .js-motion [data-unearth-bg] {
        clip-path: inset(0 0 100% 0);
        -webkit-clip-path: inset(0 0 100% 0);
        will-change: clip-path;
      }

      /* Section bg veil (lavoro paper on home, archè bridge on home) */
      .js-motion [data-curtain-veil] { transform: scaleY(1); transform-origin: top center; will-change: transform; }

      /* Home opening — support elements (eyebrow, lead, scroll-hint, portrait) */
      .js-opening-pending #hero-portrait,
      .js-opening-pending #hero-eyebrow,
      .js-opening-pending #hero-lead,
      .js-opening-pending #hero-scroll-hint { opacity: 0; will-change: opacity; }
    </style>

    <slot name="head" />
  </head>
  <body class="bg-ink text-bone font-body antialiased">
    <Header />
    <slot />
    <Footer />

    {/* Motion runtime — runs site-wide so /storia, /metodo, /perizie, /arche
        all get the calm scroll-reveal. Hero opening only fires on the home. */}
    <script>
      import '../scripts/home-motion';
    </script>

    {/* Safety net: only fires if motion JS never loaded.
        The motion script clears window.__motionSafety on init. */}
    <script is:inline>
      window.__motionSafety = setTimeout(function () {
        document.documentElement.classList.remove('js-opening-pending');
        document.documentElement.classList.remove('js-motion');
      }, 5000);
    </script>
  </body>
</html>

<style is:global>
  /* MOVE 6 — name-match morph DISABLED.
     <ViewTransitions /> stays active (default cross-fade, no white flash).
     Re-enable by uncommenting these two rules. */
  /*
  .vt-arche-heading { view-transition-name: arche-heading; }
  .vt-storia-heading { view-transition-name: storia-heading; }
  */

  /* The authoritative pre-hide CSS lives in <style is:inline> above so it
     applies before first paint in both dev and prod. Rules below remain
     for safety; they mirror the inline ones. */
  .js-motion [data-reveal] { opacity: 0; transform: translateY(56px); }
  .js-motion [data-page-entry] { opacity: 0; transform: translateY(56px); }
  .js-motion [data-reveal]:has(.word),
  .js-motion [data-page-entry]:has(.word),
  .js-motion [data-unearth-hero] { opacity: 1; transform: none; }
  .js-motion .word {
    display: inline-block;
    clip-path: inset(0 0 100% 0);
    -webkit-clip-path: inset(0 0 100% 0);
  }
  .js-motion [data-unearth-bg] {
    clip-path: inset(0 0 100% 0);
    -webkit-clip-path: inset(0 0 100% 0);
  }
  .js-motion [data-curtain-veil] { transform: scaleY(1); transform-origin: top center; }

  /* Pre-hide for the opening reveal — unused but kept for back-compat. */
  .js-opening-pending .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    will-change: transform, opacity;
  }
  .js-opening-pending .hero-bg-image {
    transform: scale(1.08);
    will-change: transform;
  }
  .js-opening-pending #hero-portrait {
    opacity: 0;
    will-change: opacity;
  }
  .js-opening-pending #hero-eyebrow,
  .js-opening-pending #hero-lead,
  .js-opening-pending #hero-scroll-hint {
    opacity: 0;
    will-change: opacity;
  }

  /* Disable any view-transition animation when the user opts out */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-group(*),
    ::view-transition-old(*),
    ::view-transition-new(*) { animation: none !important; }
  }
</style>
